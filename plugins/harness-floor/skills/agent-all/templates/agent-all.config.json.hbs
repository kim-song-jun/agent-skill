{
  "language": "{{language}}",
  "artifact": {
    "root": ".agent-skill",
    "exportDocs": false
  },
  "defaults": {
    "maxIter": {{maxIter}},
    "maxCostUSD": {{maxCostUSD}},
    "waveSize": "{{waveSize}}",
    "brainstormFirst": true,
    "createPR": true
  },
  "telemetry": {
    "cost": {
      "enabled": true,
      "warnAtRatio": 0.8,
      "fallbackUSDPerKChar": 0.0015,
      "modelRates": {}
    }
  },
  "waves": {
    "small":  { "maxParallel": 2,  "rolesAllowed": ["dev", "reviewer"] },
    "medium": { "maxParallel": 4,  "rolesAllowed": ["dev", "frontend-dev", "backend-dev", "designer", "reviewer", "quality-debt-reviewer"] },
    "large":  { "maxParallel": 8,  "rolesAllowed": ["dev", "frontend-dev", "backend-dev", "designer", "qa-*", "reviewer", "quality-debt-reviewer", "doc-writer"] }
  },
  "loop": {
    "maxIter": {{maxIter}},
    "breakCondition": "{{breakCondition}}",
    "stableIters": 1,
    "maxRuntimeSec": null,
    "maxRepeatedFailureSignature": 3
  },
  "gates": {
    "specReview": true,
    "qualityReview": true,
    "adversarialVerify": true,
    "blockOnCritical": true
  },
  "policy": {
    "qualityDebt": {
      "enabled": true,
      "allowPaths": [],
      "allowRules": [],
      "justifications": []
    }
  },
  "security": {
    "redaction": {
      "enabled": true,
      "allowPaths": [],
      "allowRules": [],
      "failOn": ["high"],
      "maskOn": ["high", "medium"]
    }
  },
  "pr": {
    "branchPrefix": "feat/agent-all/",
    "baseBranch": "main"
  }
}
