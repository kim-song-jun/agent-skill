{
  "language": "{{language}}",
  "defaults": {
    "maxIter": {{maxIter}},
    "maxCostUSD": {{maxCostUSD}},
    "waveSize": "{{waveSize}}",
    "brainstormFirst": true,
    "createPR": true,
    "dispatch": "auto"
  },
  "waves": {
    "small":  { "maxParallel": 2,  "rolesAllowed": ["dev", "reviewer"] },
    "medium": { "maxParallel": 4,  "rolesAllowed": ["dev", "reviewer", "verification-reviewer", "qa-reviewer"] },
    "large":  { "maxParallel": 8,  "rolesAllowed": ["dev", "reviewer", "orchestrator", "verification-reviewer", "qa-reviewer", "design-reviewer", "security-reviewer", "data-reviewer", "integration-dev"] }
  },
  "loop": {
    "breakCondition": "{{breakCondition}}",
    "stableIters": 1
  },
  "gates": {
    "specReview": true,
    "qualityReview": true,
    "blockOnCritical": true
  },
  "pr": {
    "branchPrefix": "feat/agent-all/",
    "baseBranch": "main"
  }
}
