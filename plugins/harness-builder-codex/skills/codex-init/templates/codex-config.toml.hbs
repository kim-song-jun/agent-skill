# Codex config snippet produced by /codex-init.
# Review and merge this into ~/.codex/config.toml manually.

[hooks]
{{#if operationalProfile}}
PreToolUse = [
  { matcher = ".*", hooks = [{ type = "command", command = {{hook_command_pretool_toml}} }] }
]
{{/if}}
{{#if liteProfile}}
# Lite mode does not install a repo-local PreToolUse policy hook.
{{/if}}
SessionStart = [
  { hooks = [{ type = "command", command = {{hook_command_sessionstart_toml}} }] }
]
{{#if mcp_servers_block}}

{{mcp_servers_block}}
{{/if}}
