# thrift: thrift-posttool-summariser-trigger
# After each tool call, accumulate output size and emit a stderr
# system reminder if the summariser threshold is hit. Codex routes
# stderr from hooks to the TUI as a system reminder.
[[hooks.PostToolUse]]
matcher = ".*"

[[hooks.PostToolUse.hooks]]
type = "command"
command = "node \"{{hooksDir}}/thrift-posttool-summariser-trigger.mjs\""
timeout = 15
statusMessage = "Checking thrift summary threshold"
# end thrift: thrift-posttool-summariser-trigger
