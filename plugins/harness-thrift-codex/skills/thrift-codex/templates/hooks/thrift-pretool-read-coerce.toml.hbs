# thrift: thrift-pretool-read-coerce
# Suggests ctx_execute_file via context-mode-codex (when present) for
# large file reads. Codex's "read" surface is implicit (the model reads
# files directly), so this matcher targets apply_patch read-side calls
# and the explicit `read_file` MCP tool if present.
[[hooks.PreToolUse]]
matcher = "^(read_file|mcp__.*__read_file)$"

[[hooks.PreToolUse.hooks]]
type = "command"
command = "node \"{{hooksDir}}/thrift-pretool-read-coerce.mjs\""
timeout = 10
statusMessage = "Checking read-size thrift policy"
# end thrift: thrift-pretool-read-coerce
