# thrift: thrift-pretool-bash-telemetry
# Observes Codex Bash calls and records coercion telemetry.
[[hooks.PreToolUse]]
matcher = "^Bash$"

[[hooks.PreToolUse.hooks]]
type = "command"
command = "node \"{{hooksDir}}/thrift-pretool-bash-telemetry.mjs\""
timeout = 10
statusMessage = "Recording Bash thrift telemetry"
# end thrift: thrift-pretool-bash-telemetry
