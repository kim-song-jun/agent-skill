#!/usr/bin/env node
// thrift-agentstop-audit (Copilot) — fires Phase 5 on Copilot's agentStop
// hook (equivalent to CC's SessionEnd). Writes the audit report and
// optionally mirrors through a host memory adapter.

import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
import { resolve, dirname } from "node:path";

const ROOT = process.env.COPILOT_PROJECT_DIR || process.env.CLAUDE_PROJECT_DIR || ".";
const CONFIG_PATH = resolve(ROOT, ".thrift.json");
const STATE_PATH = resolve(ROOT, ".thrift-state.json");

async function main() {
  const { loadConfig } = await import(
    resolve(import.meta.dirname || ".", "../../lib/config-loader.mjs")
  );
  const { readState, writeState, recordPhase } = await import(
    resolve(import.meta.dirname || ".", "../../lib/metrics-collector.mjs")
  );
  const { buildAuditContext } = await import(
    resolve(import.meta.dirname || ".", "../../lib/audit-renderer.mjs")
  );
  const { render } = await import(
    resolve(import.meta.dirname || ".", "../../lib/render.mjs")
  );
  const { storeMemoryWrite } = await import(
    resolve(import.meta.dirname || ".", "../../lib/store-memory-bridge.mjs")
  );

  const cr = loadConfig(CONFIG_PATH);
  if (!cr.ok) process.exit(0);
  const config = cr.config;

  const state = readState(STATE_PATH);
  recordPhase(state, 5);

  const ctx = buildAuditContext({ state, config, now: new Date() });

  const tplPath = resolve(import.meta.dirname || ".", "../audit-report.md.hbs");
  let tpl;
  try {
    tpl = readFileSync(tplPath, "utf-8");
  } catch {
    process.exit(0);
  }

  const out = render(tpl, ctx);

  const dateStr = new Date().toISOString().slice(0, 10);
  const outputPath = resolve(ROOT, config.audit.outputPath.replace("<date>", dateStr));
  mkdirSync(dirname(outputPath), { recursive: true });
  writeFileSync(outputPath, out);
  writeState(STATE_PATH, state);

  // Best-effort optional memory-adapter mirror.
  if (config.storeMemory?.enabled && config.audit?.mirrorToStoreMemory) {
    try {
      await storeMemoryWrite({
        key: `${config.storeMemory?.keyPrefix || "thrift/"}audit/${dateStr}`,
        value: { reportPath: outputPath, state, at: new Date().toISOString() },
        scope: config.storeMemory?.scope || "repository",
        invoker: null,
        fallbackRoot: ROOT,
      });
    } catch { /* non-fatal */ }
  }

  console.error(`<system-reminder>thrift-copilot audit written: ${outputPath}</system-reminder>`);
  process.exit(0);
}

main().catch(() => process.exit(0));
