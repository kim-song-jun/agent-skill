#!/usr/bin/env node
// thrift-pretool-bash-telemetry (Copilot) — observes bash/powershell tool calls
// and records telemetry for the audit report. Does NOT coerce (that's
// context-mode-copilot-router's job, if installed).
//
// Input: preToolUse hook payload from Copilot via stdin (JSON):
//   { tool_input: { command: "..." }, ... }   // assumed shape
//
// The hook stdin payload shape is assumed per
//   plugins/harness-builder-copilot/skills/copilot-init/templates/hooks/.

import { readFileSync } from "node:fs";
import { resolve } from "node:path";

const STATE_PATH = resolve(process.env.COPILOT_PROJECT_DIR || process.env.CLAUDE_PROJECT_DIR || ".", ".thrift-state.json");

async function main() {
  let payload = {};
  try {
    const stdin = readFileSync(0, "utf-8");
    if (stdin.trim()) payload = JSON.parse(stdin);
  } catch {
    process.exit(0);
  }

  const cmd = payload?.tool_input?.command || "";
  if (!cmd) process.exit(0);

  const largeBashPatterns = [/^find\b/, /^git log\b/, /^git diff\b/, /^cat\b/, /^ls -[lR]/, /^grep -r\b/, /^npm test\b/, /^tree\b/];
  const likelyLarge = largeBashPatterns.some((re) => re.test(cmd));

  if (likelyLarge) {
    const { readState, writeState, recordCoercion } = await import(
      resolve(import.meta.dirname || ".", "../../lib/metrics-collector.mjs")
    );
    const state = readState(STATE_PATH);
    recordCoercion(state, {
      tool: payload?.tool_name || payload?.toolName || "bash",
      suggestion: `ctx_execute(language: "shell", code: ${JSON.stringify(cmd)})`,
      accepted: false,
    });
    writeState(STATE_PATH, state);
  }

  process.exit(0);
}

main().catch(() => process.exit(0));
