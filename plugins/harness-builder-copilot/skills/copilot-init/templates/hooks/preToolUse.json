{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "matcher": "bash|powershell",
        "bash": "if [ -f .copilot/agent-all/lib/hooks/pre-tool-use-policy.mjs ]; then node .copilot/agent-all/lib/hooks/pre-tool-use-policy.mjs; fi",
        "powershell": "if (Test-Path .copilot/agent-all/lib/hooks/pre-tool-use-policy.mjs) { node .copilot/agent-all/lib/hooks/pre-tool-use-policy.mjs }",
        "timeoutSec": 10
      }
    ]
  }
}
