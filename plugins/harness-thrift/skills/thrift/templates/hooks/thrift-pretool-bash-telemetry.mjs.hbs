#!/usr/bin/env node
// thrift-pretool-bash-telemetry — observes Bash tool calls and records
// telemetry for the audit report. Does NOT coerce (that's context-mode-router's
// job per the hook-precedence spike).
//
// Input: PreToolUse hook payload from CC stdin (JSON):
//   { tool_input: { command: "..." }, ... }
// Output: passes through (exit 0); appends a coercion record to .thrift-state.json.

import { readFileSync } from "node:fs";
import { resolve } from "node:path";

const STATE_PATH = resolve(process.env.CLAUDE_PROJECT_DIR || ".", ".thrift-state.json");

async function main() {
  let payload = {};
  try {
    const stdin = readFileSync(0, "utf-8");
    if (stdin.trim()) payload = JSON.parse(stdin);
  } catch {
    // No payload — exit silently.
    process.exit(0);
  }

  const cmd = payload?.tool_input?.command || "";
  if (!cmd) process.exit(0);

  // Heuristic: commands that often produce large output.
  const largeBashPatterns = [/^find\b/, /^git log\b/, /^git diff\b/, /^cat\b/, /^ls -[lR]/, /^grep -r\b/, /^npm test\b/, /^tree\b/];
  const likelyLarge = largeBashPatterns.some((re) => re.test(cmd));

  if (likelyLarge) {
    // Lazy import to keep startup fast for the common no-op case.
    const { readState, writeState, recordCoercion } = await import(
      resolve(import.meta.dirname || ".", "../../lib/metrics-collector.mjs")
    );
    const state = readState(STATE_PATH);
    recordCoercion(state, {
      tool: "Bash",
      suggestion: `ctx_execute(language: "shell", code: ${JSON.stringify(cmd)})`,
      accepted: false, // PreToolUse fires before the model decides; we record at "suggested" stage
    });
    writeState(STATE_PATH, state);
  }

  // Always exit 0 — telemetry-only, never blocks.
  process.exit(0);
}

main().catch(() => process.exit(0));
