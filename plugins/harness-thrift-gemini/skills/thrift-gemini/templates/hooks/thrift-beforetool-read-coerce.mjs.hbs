#!/usr/bin/env node
// thrift-beforetool-read-coerce (Gemini port) — suggests ctx_execute_file
// for large `read_file` calls.
//
// Input: BeforeTool hook payload (JSON via stdin) with
//   tool_input.absolute_path (Gemini's read_file uses absolute_path,
//   not file_path).

import { readFileSync, writeFileSync, statSync, existsSync } from "node:fs";
import { resolve } from "node:path";

const ROOT = process.env.GEMINI_PROJECT_DIR || process.env.CLAUDE_PROJECT_DIR || ".";
const STATE_PATH = resolve(ROOT, ".thrift-state.json");
const COERCE_THRESHOLD_BYTES = 200 * 80; // ~200 lines × 80 chars/line

function readState() {
  if (!existsSync(STATE_PATH)) return { coercions: [], phases: [] };
  try {
    return JSON.parse(readFileSync(STATE_PATH, "utf-8"));
  } catch {
    return { coercions: [], phases: [] };
  }
}

function writeState(state) {
  try {
    writeFileSync(STATE_PATH, JSON.stringify(state, null, 2));
  } catch {}
}

async function main() {
  let payload = {};
  try {
    const stdin = readFileSync(0, "utf-8");
    if (stdin.trim()) payload = JSON.parse(stdin);
  } catch {
    process.exit(0);
  }

  // Gemini read_file uses absolute_path; tolerate file_path for cross-CLI
  // payload reuse.
  const filePath = payload?.tool_input?.absolute_path || payload?.tool_input?.file_path;
  if (!filePath || !existsSync(filePath)) process.exit(0);

  let bytes = 0;
  try { bytes = statSync(filePath).size; } catch { process.exit(0); }

  if (bytes < COERCE_THRESHOLD_BYTES) process.exit(0);

  // File is large — emit a suggestion via stderr (Gemini surfaces as
  // system message in the next coordinator turn).
  console.error(`<system-reminder>thrift: ${filePath} is ${bytes} bytes. If you're reading to analyze (not edit), prefer ctx_execute_file to keep raw contents out of context.</system-reminder>`);

  // Record telemetry.
  const state = readState();
  state.coercions ??= [];
  state.coercions.push({
    at: new Date().toISOString(),
    tool: "read_file",
    suggestion: `ctx_execute_file(path: ${JSON.stringify(filePath)})`,
    accepted: false,
  });
  writeState(state);

  process.exit(0);
}

main().catch(() => process.exit(0));
